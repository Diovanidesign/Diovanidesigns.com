    <script>
        // Mettre à jour automatiquement l'année de copyright
        document.getElementById('current-year').textContent = new Date().getFullYear();

        // Gestion du Menu Mobile
        const menuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');

        menuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });

        // Masquer le menu mobile lors d'un clic sur un lien
        const mobileLinks = mobileMenu.querySelectorAll('a');
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => {
                mobileMenu.classList.add('hidden');
            });
        });

        // --- Comparateur Figma vs Code (Slider Interactif) ---
        const sliderContainer = document.getElementById('slider-container');
        const designLayer = document.getElementById('design-layer');
        const sliderLine = document.getElementById('slider-line');

        function moveSlider(x) {
            const containerRect = sliderContainer.getBoundingClientRect();
            let position = ((x - containerRect.left) / containerRect.width) * 100;
            
            // Verrous pour ne pas dépasser les limites
            if (position < 0) position = 0;
            if (position > 100) position = 100;

            // Appliquer le clip-path et la position de la ligne
            designLayer.style.clipPath = `inset(0 0 0 ${position}%)`;
            sliderLine.style.left = `${position}%`;
        }

        // Événements pour la souris
        let isDragging = false;
        
        sliderLine.addEventListener('mousedown', (e) => {
            isDragging = true;
            e.preventDefault();
        });

        window.addEventListener('mouseup', () => {
            isDragging = false;
        });

        window.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            moveSlider(e.clientX);
        });

        // Prise en charge des écrans tactiles mobiles
        sliderLine.addEventListener('touchstart', (e) => {
            isDragging = true;
        });

        window.addEventListener('touchend', () => {
            isDragging = false;
        });

        window.addEventListener('touchmove', (e) => {
            if (!isDragging) return;
            if (e.touches.length > 0) {
                moveSlider(e.touches[0].clientX);
            }
        });


        // --- Système de Filtrage Dynamique du Portfolio ---
        function filterProjects(category) {
            const cards = document.querySelectorAll('.project-card');
            
            // Gérer l'état actif des boutons
            const btnAll = document.getElementById('filter-all');
            const btnDesign = document.getElementById('filter-design');
            const btnWeb = document.getElementById('filter-web');

            // Réinitialiser les classes actives de tous les boutons
            [btnAll, btnDesign, btnWeb].forEach(btn => {
                btn.className = "px-5 py-2 rounded-lg text-sm font-semibold transition-all duration-300 text-zinc-400 hover:text-white";
            });

            // Assigner le style actif au bon bouton
            if (category === 'all') btnAll.className = "px-5 py-2 rounded-lg text-sm font-semibold transition-all duration-300 bg-white text-black";
            if (category === 'design') btnDesign.className = "px-5 py-2 rounded-lg text-sm font-semibold transition-all duration-300 bg-white text-black";
            if (category === 'web') btnWeb.className = "px-5 py-2 rounded-lg text-sm font-semibold transition-all duration-300 bg-white text-black";

            // Filtrer les cartes
            cards.forEach(card => {
                if (category === 'all') {
                    card.classList.remove('hidden');
                } else if (card.classList.contains(category)) {
                    card.classList.remove('hidden');
                } else {
                    card.classList.add('hidden');
                }
            });
        }


        // --- Formulaire de Contact Interactif ---
        function handleContactSubmit(event) {
            event.preventDefault();
            
            // Masquer le formulaire et afficher le message de réussite
            const form = document.getElementById('contact-form');
            const successMsg = document.getElementById('success-msg');
            
            form.classList.add('hidden');
            successMsg.classList.remove('hidden');
        }

        function resetContactForm() {
            const form = document.getElementById('contact-form');
            const successMsg = document.getElementById('success-msg');
            
            form.reset();
            form.classList.remove('hidden');
            successMsg.classList.add('hidden');
        }
    </script>
